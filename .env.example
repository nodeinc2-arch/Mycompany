# Pay.ca labs — environment variables. Copy to .env.local and fill in.
# Nothing here is required to run the site; these only enable optional features.

# --- Labs gating -----------------------------------------------------------
# Set to 1 to expose /labs/* and the payroll APIs (always required in prod).
LABS_ENABLED=

# --- Session signing (required in production) ------------------------------
# Secret used to sign the Pay.ca session cookie (HMAC), the server-trusted
# source of which tenant a request belongs to. In local dev an insecure
# built-in fallback is used if unset; in production SESSION_SECRET is REQUIRED
# and the app refuses to sign/verify sessions without it (fails closed).
# Generate one with:  openssl rand -base64 32
SESSION_SECRET=

# --- Durable store (Cloudflare D1) -----------------------------------------
# The audit log, billing entitlement and tenants persist to a D1 database bound
# as PAYCA_DB in wrangler.toml. There is nothing to set here — the binding is
# configured in wrangler.toml and applied with `pnpm db:migrate`. Until the DB
# is bound, those stores fall back to a non-durable in-memory Map. See
# docs/d1-setup.md.

# --- Payroll Micro AI (optional) -------------------------------------------
# Local Ollama for the grounded payroll assistant. Defaults shown.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# --- Stripe billing (optional) ---------------------------------------------
# SIMPLEST PATH — a Stripe Payment Link for the one-time onboarding/pilot fee.
# No API keys or webhook required: create a Payment Link in the Stripe dashboard
# and paste its URL here. When set, the "Book your onboarding" button sends the
# buyer straight to it. This is the fastest way to charge the first customer.
NEXT_PUBLIC_PILOT_PAYMENT_LINK=

# Full self-serve checkout (subscription + setup fee). Optional and only needed
# once the payroll backend actually runs — until then, prefer the Payment Link
# above. Use TEST keys (sk_test_..., whsec_...) until you go live. Leave blank to
# fall back to the Payment Link, then to /get-started.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Pre-made Price IDs that match lib/labs/payroll/pricing.ts. Optional: if unset,
# checkout builds inline prices from pricing.ts so test checkouts still work.
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_SETUP=

# Public base URL used to build Stripe success/cancel redirect URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
